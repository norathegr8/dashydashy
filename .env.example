# === TikTok Creator Dashboard Config ===

# Your Apify API token (get it from https://console.apify.com/account/integrations)
APIFY_API_TOKEN=your_apify_token_here

# TikTok username(s) to scrape — comma-separated, no @ symbol
# Example: charlidamelio,khaby.lame
TIKTOK_PROFILES=username_here

# Number of recent videos to pull per profile (default: 20)
VIDEOS_PER_PROFILE=20

# === OPTIONAL — only needed if running analyze.js outside Claude Code ===
# Your Anthropic API key (https://console.anthropic.com/)
# CLAUDE_API_KEY=your_claude_api_key_here
